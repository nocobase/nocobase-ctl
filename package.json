{
  "name": "nocobase",
  "version": "0.1.4",
  "description": "NocoBase CLI",
  "type": "module",
  "main": "dist/generated/command-registry.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "dev": "./bin/dev.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "files": [
    "bin",
    "dist",
    "nocobase-cli.config.json"
  ],
  "bin": {
    "nocobase": "./bin/run.js"
  },
  "oclif": {
    "bin": "nocobase",
    "additionalHelpFlags": [
      "-h"
    ],
    "commands": {
      "strategy": "explicit",
      "target": "./dist/generated/command-registry.js"
    },
    "dirname": "nocobase-cli",
    "topicSeparator": " ",
    "topics": {
      "env": {
        "description": "Manage NocoBase project environments and update command runtimes."
      },
      "resource": {
        "description": "Work with generic collection resources."
      }
    }
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@oclif/core": "^4.10.4",
    "openapi-types": "^12.1.3",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "tsx": "^4.20.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nocobase/nocobase.git",
    "directory": "nocobase-cli"
  }
}
